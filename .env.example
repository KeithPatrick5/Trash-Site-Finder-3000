# Local-only TSF3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_PASSWORD=change-this-local-password

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Discovery: Google Places budget mode
GOOGLE_PLACES_API_KEY=
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_TEXT_SEARCH_CALLS_PER_DAY=150
GOOGLE_TEXT_SEARCH_CALLS_PER_MONTH=4500
PLACES_PAGE_SIZE=20
MAX_PAGES_PER_COMBO=3
ENABLE_GOOGLE_QUERY_VARIATIONS=false
MAX_SCAN_COMBOS=2500
MAX_SCAN_BATCH_SIZE=20
SCAN_BATCH_SIZE=20
SCAN_CONCURRENCY=1
AUDIT_CONCURRENCY=1
WORKER_SLEEP_MS=2000

# Optional AI. Blank = no OpenAI spend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Screenshots off by default.
ENABLE_SCREENSHOTS=false
SCREENSHOT_MIN_SCORE=90
MAX_DAILY_SCREENSHOTS=0
SCREENSHOTONE_ACCESS_KEY=
BROWSERLESS_TOKEN=

# Email disabled by default.
RESEND_API_KEY=
OUTBOUND_FROM=Keith <you@yourdomain.com>
REPLY_TO_EMAIL=
COMPANY_POSTAL_ADDRESS=Your mailing address here
WORKER_SEND_APPROVED_EMAILS=true
MAX_DAILY_EMAILS=0
DAILY_SEND_LIMIT=0
SEND_RATE_LIMIT=0
MAX_EMAIL_BATCH_SIZE=5
REQUIRE_MANUAL_APPROVAL=true

# Deal path
UPWORK_PROFILE_URL=
NEXT_PUBLIC_UPWORK_PROFILE_URL=
