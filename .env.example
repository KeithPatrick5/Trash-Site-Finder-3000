# Protect the dashboard/API with HTTP Basic Auth. Username can be anything; password must match this.
APP_PASSWORD=change-this-password
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required for live business discovery
GOOGLE_PLACES_API_KEY=
GOOGLE_PAGESPEED_API_KEY=

# Optional AI message + reply classification. Without this, app uses local templates/rules.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional screenshot links for visual audit. Pick one provider if wanted.
SCREENSHOTONE_ACCESS_KEY=
BROWSERLESS_TOKEN=

# Optional email sending. Without this, sending is disabled and messages queue only.
RESEND_API_KEY=
OUTBOUND_FROM="Trash Site Finder <you@yourdomain.com>"
REPLY_TO_EMAIL=you@yourdomain.com
COMPANY_POSTAL_ADDRESS="Your business mailing address"

# Optional Supabase persistence. Without this, demo in-memory data is used per server process.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Safety controls
DAILY_SEND_LIMIT=25
SCAN_RATE_LIMIT=20
SEND_RATE_LIMIT=10
JOB_TICK_RATE_LIMIT=120
MAX_SCAN_COMBOS=2500
SCAN_BATCH_SIZE=10
SCAN_CONCURRENCY=3
AUDIT_CONCURRENCY=3
